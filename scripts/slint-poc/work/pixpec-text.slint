// AUTO-GENERATED by pixpec slint emitter (build-text).
// Do not edit by hand. Regenerate from __pixpec-fonts.json.

export component PixpecText {
    in property <string> text;
    in property <length> font-size;
    in property <int> font-weight;
    in property <string> font-family;
    in property <brush> text-color;
    /** When >0, fixes the inner Text width (figma autoResize=fixed-width). */
    in property <length> text-width: 0px;

    function shift() -> length {
        if (root.font-family == "Wanted Sans Variable") {
            if (root.font-size == 10px) { return 0.5px; }
            if (root.font-size == 12px) { return -0.25px; }
            if (root.font-size == 14px) { return 0px; }
            if (root.font-size == 16px) { return 0.375px; }
            if (root.font-size == 24px) { return 0.5px; }
        }
        if (root.font-family == "goorm Sans Code") {
            if (root.font-size == 16px) { return 0.625px; }
        }
        return 0px;
    }

    // Hug the inner Text's natural size — Rectangle base sizes from
    // children when no explicit dim, so PixpecText behaves like a bare
    // Text under HorizontalLayout sizing.
    min-width: root.text-width > 0px ? root.text-width : txt.preferred-width;
    min-height: txt.preferred-height;

    txt := Text {
        width: root.text-width > 0px ? root.text-width : self.preferred-width;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2 + root.shift();
        text: root.text;
        font-family: root.font-family;
        font-size: root.font-size;
        font-weight: root.font-weight;
        color: root.text-color;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}
